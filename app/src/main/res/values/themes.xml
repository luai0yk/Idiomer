<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.EIH" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimaryDark">@color/white</item>
        <item name="colorPrimary">@color/green6</item>
        <item name="colorAccent">@color/green6</item>
        <item name="colorControlHighlight">@color/green3</item>
        <item name="colorControlNormal">@color/green3</item>

        <item name="alertDialogStyle">@style/CustomDialog</item>
    </style>

    <style name="Theme.EIH.SplashScreen">
        <item name="android:windowBackground">@color/green6</item>
        <item name="android:statusBarColor">@color/green6</item>
        <item name="android:navigationBarColor">@color/green6</item>
    </style>

    <style name="CustomDialog" parent="Theme.Material3.Light.Dialog.MinWidth">
        <item name="android:windowBackground">@drawable/white_background</item>
    </style>
</resources>